{
  "compilerOptions": {
    "esModuleInterop": true,
    "sourceMap": true,
    "strictNullChecks": false,
    "declaration": true,
    "removeComments": true,
    "target": "es2025",
    "erasableSyntaxOnly": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./lib",
    "module": "commonjs"
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./src/**/*.spec.*"
  ]
}
